{
    "env": {
        "node": true,
        "es2021": true
    },
    "parser": "@typescript-eslint/parser",
    "plugins": ["@typescript-eslint"],
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended",
        "plugin:prettier/recommended"
    ],
    "rules": {
        "no-unused-vars": "warn",
        "no-console": "off",
        "@typescript-eslint/no-unused-vars": "warn",
        "prettier/prettier": "error"
    }
}